@{
    ViewData["Title"] = "Home Page";
}

<main id="site__main" class="2xl:ml-[--w-side] xl:ml-[--w-side-sm] p-2.5 h-[calc(100vh-var(--m-top))] mt-[--m-top]">

    <div class="lg:flex 2xl:gap-16 gap-12 max-w-[1065px] mx-auto w-full" id="js-oversized">

        <div class="max-w-[680px] mx-auto flex-2 w-full space-y-6">

            <div class="bg-white/50 border border-slate-100 rounded-2xl p-4 shadow-[0_2px_8px_-4px_rgba(0,0,0,0.05)] mb-2">
                <div class="flex items-center justify-between mb-2">
                    <h3 class="font-bold text-sm text-slate-500 uppercase tracking-wider">
                        Stories
                    </h3>
                    <a href="#" class="text-xs font-medium text-blue-500 hover:text-blue-600 transition">Watch all</a>
                </div>

                <div class="relative" tabindex="1" uk-slider="auto play: true;finite: true" uk-lightbox="">
                    <div class="py-2 uk-slider-container">
                        <ul class="uk-slider-items w-[calc(100%+14px)]" uk-scrollspy="target: li; cls:uk-animation-scale-up; delay: 20;repeat:true">

                            <li class="md:pr-3" uk-scrollspy-class="uk-animation-fade">
                                <div class="md:w-16 md:h-16 w-12 h-12 rounded-full relative border-2 border-dashed grid place-items-center bg-slate-50 hover:bg-slate-100 transition cursor-pointer border-slate-300 shrink-0"
                                     uk-toggle="target: #create-story">
                                    <ion-icon name="camera" class="text-2xl text-slate-500"></ion-icon>
                                </div>
                            </li>

                            <li class="md:pr-3 pr-2 hover:scale-[1.15] hover:-rotate-2 duration-300">
                                <a href="~/images/avatar/kimminju.jpg">
                                    <div class="md:w-16 md:h-16 w-12 h-12 rounded-full p-1 shadow-sm" style="background: linear-gradient(to top right, #f9ce34, #ee2a7b, #6228d7);">
                                        <img src="~/images/avatar/kimminju.jpg" class="bg-white object-cover w-full h-full rounded-full" />
                                    </div>
                                </a>
                            </li>

                            <li class="md:pr-3 pr-2 hover:scale-[1.15] hover:-rotate-2 duration-300">
                                <a href="~/images/avatar/kimminju.jpg">
                                    <div class="md:w-16 md:h-16 w-12 h-12 rounded-full p-1 shadow-sm" style="background: linear-gradient(to top right, #f9ce34, #ee2a7b, #6228d7);">
                                        <img src="~/images/avatar/user.png" class="bg-white object-cover w-full h-full rounded-full" />
                                    </div>
                                </a>
                            </li>
                            <li class="md:pr-3 pr-2">
                                <div class="md:w-16 md:h-16 w-12 h-12 bg-slate-200/60 rounded-full animate-pulse"></div>
                            </li>

                        </ul>
                    </div>
                </div>
            </div>

            <div class="bg-slate-50 border border-slate-100 rounded-xl p-5 text-sm font-medium text-slate-500 text-center shadow-sm hidden">
                Currently, there are no posts available. Would you like to create the first one?
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-slate-100 text-sm font-medium overflow-hidden">

                @* Post heading *@
                <div class="flex gap-3 sm:p-4 p-3 text-sm font-medium">
                    <a href="#">
                        <img src="~/images/avatar/kimminju.jpg" class="w-10 h-10 rounded-full object-cover" />
                    </a>
                    <div class="flex-1">
                        <a href="#">
                            <h4 class="text-black font-semibold">Kim Minju</h4>
                            <div class="text-xs text-gray-400 mt-0.5">1 day ago</div>
                        </a>
                    </div>

                    <div class="-mr-1">
                        <button type="button" class="button-icon w-8 h-8 hover:bg-slate-100 rounded-full flex items-center justify-center transition">
                            <ion-icon class="text-xl text-slate-600" name="ellipsis-horizontal"></ion-icon>
                        </button>
                        <div class="w-[245px] bg-white rounded-lg shadow-lg border border-slate-100 overflow-hidden" uk-dropdown="pos: bottom-right; animation: uk-animation-scale-up uk-transform-origin-top-right; animate-out: true; mode: click">
                            <nav class="text-sm">
                                <form>
                                    <input type="hidden" name="postId" />
                                    <button type="submit" class="w-full flex items-center gap-2 px-4 py-2.5 hover:bg-slate-50 text-slate-700 transition">
                                        <ion-icon name="lock-closed-outline" class="text-lg"></ion-icon> Set as private
                                    </button>
                                </form>
                                <hr class="border-slate-100">
                                <form asp-controller="Home" asp-action="Delete">
                                    <input type="hidden" name="postId" />
                                    <button type="submit" class="w-full flex items-center gap-2 px-4 py-2.5 hover:bg-red-50 text-red-600 transition">
                                        <ion-icon name="trash-bin-outline" class="text-lg"></ion-icon> Delete Post
                                    </button>
                                </form>
                                <form asp-controller="Home" asp-action="Report">
                                    <input type="hidden" name="postId" />
                                    <button type="submit" class="w-full flex items-center gap-2 px-4 py-2.5 hover:bg-slate-50 text-slate-700 transition">
                                        <ion-icon name="flag-outline" class="text-lg"></ion-icon> Report
                                    </button>
                                </form>
                            </nav>
                        </div>
                    </div>
                </div>

                @* Post content *@
                <div class="sm:px-4 p-5 pt-0 w-full">
                    <p class="font-normal text-slate-800 leading-relaxed">
                        Crush mo nak? Girlfriend ko ma.. 🥰
                    </p>
                </div>

                <div class="relative w-full border-y border-slate-100 bg-slate-900" style="aspect-ratio: 4 / 5;">
                    <img src="~/images/posts/kim_minju.jpg" class="w-full h-full object-cover" />
                </div>

                @* Icons/Actions *@
                <div class="sm:p-4 p-3 flex items-center gap-5 text-sm font-semibold border-b border-slate-50">
                    <div class="flex items-center gap-2 hover:text-red-500 transition cursor-pointer">
                        <div class="w-8 h-8 rounded-full bg-red-50 text-red-500 flex items-center justify-center">
                            <ion-icon class="text-lg" name="heart"></ion-icon>
                        </div>
                        <span class="text-slate-600">24</span>
                    </div>

                    <div class="flex items-center gap-2 hover:text-blue-500 transition cursor-pointer">
                        <div class="w-8 h-8 rounded-full bg-slate-100 text-slate-600 flex items-center justify-center">
                            <ion-icon class="text-lg" name="chatbubble-ellipses-outline"></ion-icon>
                        </div>
                        <span class="text-slate-600">5</span>
                    </div>

                    <div class="ml-auto">
                        <button class="w-8 h-8 rounded-full hover:bg-slate-100 text-slate-600 flex items-center justify-center transition">
                            <ion-icon class="text-lg" name="bookmark-outline"></ion-icon>
                        </button>
                    </div>
                </div>

                @* Add comment section *@
                <div class="sm:px-4 sm:py-3 p-3 bg-slate-50/50 flex items-center gap-3">
                    <img src="~/images/avatar/formal.png" class="w-8 h-8 rounded-full object-cover shadow-sm" />

                    <div class="flex-1 relative bg-white border border-slate-200 rounded-full overflow-hidden flex items-center focus-within:border-slate-300 transition">
                        <input type="text" placeholder="Add Comment..." class="w-full bg-transparent px-4 py-2 text-sm focus:outline-none placeholder-slate-400" />
                    </div>

                    <button class="text-sm font-semibold rounded-full py-1.5 px-4 bg-slate-200 hover:bg-slate-300 text-slate-700 transition">Comment</button>
                </div>

            </div>

        </div>

       <div class="flex-1 hidden lg:block w-full max-w-[320px]">
            <div class="space-y-6 sticky top-24">
                <div class="bg-transparent rounded-2xl border border-slate-200 p-5">
                    <partial name="Sidebar/_SuggestedFriends"></partial>
                    </div>

                    <div class="bg-transparent rounded-2xl border border-slate-200 p-5">
                        <partial name="Sidebar/_TrendsForYou"></partial>
                        </div>

            </div>
        </div>
        </div>
</main>

<partial name="Modals/_CreateStory"></partial>
    <partial name="Modals/_CreatePost"></partial>